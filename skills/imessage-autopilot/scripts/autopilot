class AutopilotError(RuntimeError):
    def __init__(self, code: str, message: str, *, exit_code: int = 2) -> None:
        super().__init__(message)
        self.code = code
        self.exit_code = exit_code


class RuntimeFailure(AutopilotError):
    pass


@dataclass(frozen=True)
class Paths:
    root: Path
    database: Path
    lock: Path
    log: Path

    @classmethod
    def from_root(cls, root: Path) -> "Paths":
        resolved = root.expanduser().absolute()
        return cls(
            root=resolved,
            database=resolved / "state.sqlite3",
            lock=resolved / "controller.lock",
            log=resolved / "controller.log",
        )


@dataclass(frozen=True)
class Message:
    guid: str
    chat_id: str
    sequence: int
    direction: str
    kind: str
    text: str


@dataclass(frozen=True)
class Chat:
    chat_id: str
    rowid: int
    guid: str
    label: str
    kind: str
    participants_hash: str
    participants: tuple[str, ...]
    service: str
    last_sequence: int


def compact_json(value: Any) -> str:
    return json.dumps(value, ensure_ascii=False, sort_keys=True, separators=(",", ":"))


def emit(value: dict[str, Any], *, stream: Any = sys.stdout) -> None:
    print(compact_json(value), file=stream, flush=True)


def digest(value: str) -> str:
    return hashlib.sha256(value.encode("utf-8")).hexdigest()


def string_field(
    value: Any,
    name: str,
    *,
    allow_empty: bool = False,
    maximum: int = 8_192,
) -> str:
    if not isinstance(value, str):
        raise AutopilotError("invalid_contract", f"{name} must be a string")
    result = value.strip()
    if not allow_empty and not result:
        raise AutopilotError("invalid_contract", f"{name} cannot be empty")
    if len(result) > maximum:
        raise AutopilotError("invalid_contract", f"{name} is too long")
    return result


def normalize_contract(raw: Any) -> dict[str, Any]:
    if not isinstance(raw, dict) or raw.get("version") != CONTRACT_VERSION:
        raise AutopilotError("invalid_contract", "contract version must be 1")
    allowed = {
        "version",
        "owner_label",
        "reply_style",
        "included_chats",
        "disclosure",
    }
    if set(raw) - allowed:
        raise AutopilotError("invalid_contract", "contract contains unsupported fields")
    disclosure = raw.get("disclosure")
    if disclosure not in {"none", "explicit"}:
        raise AutopilotError(
            "invalid_contract", "disclosure must be 'none' or 'explicit'"
        )
    entries = raw.get("included_chats")
    if not isinstance(entries, list) or not entries:
        raise AutopilotError("invalid_contract", "included_chats cannot be empty")
    if len(entries) > 100:
        raise AutopilotError("invalid_contract", "included_chats is too large")
    chats: list[dict[str, str]] = []
    seen: set[str] = set()
    for index, item in enumerate(entries):
        if not isinstance(item, dict) or set(item) - {
            "id",
            "kind",
            "participants_hash",
        }:
            raise AutopilotError(
                "invalid_contract", f"included_chats[{index}] is invalid"
            )
        chat_id = string_field(item.get("id"), f"included_chats[{index}].id", maximum=128)
        if not chat_id.startswith("messages-chat:") or chat_id in seen:
            raise AutopilotError(
                "invalid_contract", "included chat IDs must be unique discovery IDs"
            )
        kind = item.get("kind")
        if kind not in {"direct", "group"}:
            raise AutopilotError("invalid_contract", "chat kind must be direct or group")
        participants_hash = string_field(
            item.get("participants_hash"),
            f"included_chats[{index}].participants_hash",
            maximum=128,
        )
        chats.append(
            {
                "id": chat_id,
                "kind": kind,
                "participants_hash": participants_hash,
            }
        )
        seen.add(chat_id)
    chats.sort(key=lambda item: item["id"])
    return {
        "version": CONTRACT_VERSION,
        "owner_label": string_field(raw.get("owner_label"), "owner_label", maximum=200),
        "reply_style": string_field(raw.get("reply_style"), "reply_style"),
        "included_chats": chats,
        "disclosure": disclosure,
    }


def default_state_root() -> Path:
    configured = os.environ.get("IMESSAGE_AUTOPILOT_STATE_DIR", "").strip()
    if configured:
        return Path(configured)
    return Path(tempfile.gettempdir()) / f"imessage-autopilot-{os.getuid()}"


def ensure_private_root(path: Path) -> None:
    path.mkdir(mode=0o700, parents=True, exist_ok=True)
    info = path.lstat()
    if stat.S_ISLNK(info.st_mode) or not stat.S_ISDIR(info.st_mode):
        raise AutopilotError("unsafe_state", "state path must be a real directory")
    if info.st_uid != os.getuid() or stat.S_IMODE(info.st_mode) & 0o077:
        raise AutopilotError("unsafe_state", "state directory must be private and owned by you")


def open_private(path: Path, flags: int, mode: int = 0o600) -> int:
    no_follow = getattr(os, "O_NOFOLLOW", 0)
    descriptor = os.open(path, flags | no_follow, mode)
    info = os.fstat(descriptor)
    if (
        not stat.S_ISREG(info.st_mode)
        or info.st_uid != os.getuid()
        or stat.S_IMODE(info.st_mode) & 0o077
    ):
        os.close(descriptor)
        raise AutopilotError("unsafe_state", f"unsafe state file: {path.name}")
    return descriptor


def asset_paths() -> tuple[Path, Path]:
    assets = Path(__file__).resolve().parent.parent / "assets"
    return assets / "runtime-prompt.md", assets / "reply-schema.json"


def find_codex() -> Path | None:
    configured = os.environ.get("CODEX_BINARY", "").strip()
    found = configured or shutil.which("codex")
    if not found:
        return None
    path = Path(found).expanduser().absolute()
    return path if path.is_file() and os.access(path, os.X_OK) else None


def codex_environment(*, sqlite_home: Path | None = None) -> dict[str, str]:
    allowed = {
        "PATH",
        "HOME",
        "CODEX_HOME",
        "TMPDIR",
        "TMP",
        "TEMP",
        "LANG",
        "LC_ALL",
        "SSL_CERT_FILE",
        "SSL_CERT_DIR",
        "HTTPS_PROXY",
        "HTTP_PROXY",
        "ALL_PROXY",
        "NO_PROXY",
        "USER",
        "LOGNAME",
    }
    environment = {key: value for key, value in os.environ.items() if key in allowed}
    if sqlite_home is not None:
        environment["CODEX_SQLITE_HOME"] = str(sqlite_home)
    environment["CODEX_INTERNAL_ORIGINATOR_OVERRIDE"] = "imessage_autopilot"
    environment["NO_COLOR"] = "1"
    environment["RUST_LOG"] = "error"
    return environment


def codex_app_server_available(binary: Path) -> bool:
    try:
        result = subprocess.run(
            [str(binary), "app-server", "--help"],
            stdin=subprocess.DEVNULL,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            timeout=10,
            env=codex_environment(),
            check=False,
        )
    except (OSError, subprocess.TimeoutExpired):
        return False
    return result.returncode == 0


class MessagesSource:
    """Minimal read-only access to a selected Messages-shaped SQLite database."""

    REQUIRED = {
        "message": {"guid", "text", "is_from_me"},
        "chat": {"guid", "chat_identifier"},
        "chat_message_join": {"chat_id", "message_id"},
        "handle": {"id"},
        "chat_handle_join": {"chat_id", "handle_id"},
    }

    def __init__(self, path: Path) -> None:
        self.path = path.expanduser().absolute()

    def _file(self) -> os.stat_result:
        try:
            info = self.path.lstat()
        except OSError as exc:
            raise AutopilotError(
                "messages_unavailable", "Messages database is unavailable or unreadable"
            ) from exc
        if stat.S_ISLNK(info.st_mode) or not stat.S_ISREG(info.st_mode):
            raise AutopilotError("unsafe_messages_database", "Messages database must be a regular file")
        return info

    def _connect(self) -> sqlite3.Connection:
        self._file()
        database: sqlite3.Connection | None = None
        try:
            database = sqlite3.connect(
                self.path.as_uri() + "?mode=ro&cache=private",
                uri=True,
                timeout=2,
                isolation_level=None,
            )
            database.row_factory = sqlite3.Row
            database.execute("PRAGMA query_only=ON")
            database.execute("PRAGMA trusted_schema=OFF")
            return database
        except sqlite3.DatabaseError as exc:
            if database is not None:
                database.close()
            raise AutopilotError(
                "messages_database_error", "Messages database could not be opened read-only"
            ) from exc

    @staticmethod
    def _columns(database: sqlite3.Connection, table: str) -> set[str]:
        return {str(row[1]).casefold() for row in database.execute(f"PRAGMA table_info({table})")}

    def schema(self) -> dict[str, set[str]]:
        database = self._connect()
        try:
            schema = {table: self._columns(database, table) for table in self.REQUIRED}
        finally:
            database.close()
        missing = {
            table: sorted(required - schema[table])
            for table, required in self.REQUIRED.items()
            if not required <= schema[table]
        }
        if missing:
            summary = ", ".join(
                f"{table}({','.join(columns)})" for table, columns in sorted(missing.items())
            )
            raise AutopilotError(
                "unsupported_messages_schema", f"Messages schema is missing {summary}"
            )
        return schema

    def validate(self) -> None:
        self.schema()

    @staticmethod
    def _chat_id(rowid: int, guid: str, service: str, identifier: str) -> str:
        stable = compact_json(
            {
                "rowid": rowid,
                "guid": guid.strip(),
                "service": service,
                "identifier": identifier,
            }
        )
        return "messages-chat:" + digest(stable)

    @staticmethod
    def _participant_hash(participants: list[str]) -> str:
        return digest(compact_json(sorted(set(participants))))

    @staticmethod
    def _participants(database: sqlite3.Connection, chat_rowid: int) -> tuple[str, ...]:
        rows = database.execute(
            "SELECT h.id FROM chat_handle_join chj JOIN handle h "
            "ON h.ROWID=chj.handle_id WHERE chj.chat_id=? ORDER BY h.id",
            (chat_rowid,),
        ).fetchall()
        return tuple(
            sorted({str(row[0]).strip() for row in rows if str(row[0] or "").strip()})
        )

    def _all_chats(self, database: sqlite3.Connection) -> list[Chat]:
        schema = {table: self._columns(database, table) for table in self.REQUIRED}
        chat_columns = schema["chat"]
        service = "c.service_name" if "service_name" in chat_columns else "''"
        display = "c.display_name" if "display_name" in chat_columns else "''"
        rows = database.execute(
            "SELECT c.ROWID AS rowid,c.guid,c.chat_identifier,"
            f"{service} AS service,{display} AS display_name,"
            "COALESCE(MAX(m.ROWID),-1) AS last_sequence "
            "FROM chat c LEFT JOIN chat_message_join cmj ON cmj.chat_id=c.ROWID "
            "LEFT JOIN message m ON m.ROWID=cmj.message_id GROUP BY c.ROWID"
        ).fetchall()
        result: list[Chat] = []
        for row in rows:
            participants = self._participants(database, int(row["rowid"]))
            kind = "group" if len(participants) > 1 else "direct"
            guid = str(row["guid"] or "").strip()
            identifier = str(row["chat_identifier"] or "").strip()
            service_name = str(row["service"] or "").strip()
            label = str(row["display_name"] or "").strip() or identifier or guid
            result.append(
                Chat(
                    chat_id=self._chat_id(int(row["rowid"]), guid, service_name, identifier),
                    rowid=int(row["rowid"]),
                    guid=guid,
                    label=label,
                    kind=kind,
                    participants_hash=self._participant_hash(list(participants)),
                    participants=participants,
                    service=service_name,
                    last_sequence=int(row["last_sequence"]),
                )
            )
        return result

    def list_chats(self, *, limit: int, search: str = "") -> list[Chat]:
        database = self._connect()
        try:
            chats = self._all_chats(database)
        except sqlite3.DatabaseError as exc:
            raise AutopilotError("messages_database_error", "Messages chats could not be listed") from exc
        finally:
            database.close()
        needle = search.casefold()
        if needle:
            chats = [
                chat
                for chat in chats
                if needle in " ".join((chat.label, chat.guid, *chat.participants)).casefold()
            ]
        chats.sort(key=lambda chat: chat.last_sequence, reverse=True)
        return chats[:limit]

    def selected(self, scope: dict[str, dict[str, str]]) -> dict[str, Chat]:
        database = self._connect()
        try:
            available = {chat.chat_id: chat for chat in self._all_chats(database)}
        except sqlite3.DatabaseError as exc:
            raise AutopilotError("messages_database_error", "Messages scope could not be resolved") from exc
        finally:
            database.close()
        missing = sorted(set(scope) - set(available))
        if missing:
            raise AutopilotError("scope_missing", "one or more selected chats no longer exist")
        selected = {chat_id: available[chat_id] for chat_id in scope}
        for chat_id, chat in selected.items():
            expected = scope[chat_id]
            if chat.kind != expected["kind"] or chat.participants_hash != expected["participants_hash"]:
                raise AutopilotError(
                    "scope_changed", f"participant membership changed for {chat_id}"
                )
            if not chat.guid:
                raise AutopilotError("chat_not_sendable", f"selected chat has no Messages GUID: {chat_id}")
        return selected

    def validate_scope(self, selected: dict[str, Chat]) -> None:
        database = self._connect()
        try:
            for chat in selected.values():
                row = database.execute(
                    "SELECT guid FROM chat WHERE ROWID=?", (chat.rowid,)
                ).fetchone()
                participants = self._participants(database, chat.rowid)
                if (
                    row is None
                    or str(row[0] or "").strip() != chat.guid
                    or self._participant_hash(list(participants)) != chat.participants_hash
                ):
                    raise AutopilotError(
                        "scope_changed", f"participant membership changed for {chat.chat_id}"
                    )
        except sqlite3.DatabaseError as exc:
            raise AutopilotError("messages_database_error", "Messages scope could not be verified") from exc
        finally:
            database.close()

    @staticmethod
    def _kind(
        text: Any,
        attachment: Any,
        associated_guid: Any,
        item_type: Any,
        balloon_bundle_id: Any,
    ) -> tuple[str, str]:
        body = text if isinstance(text, str) else ""
        if (
            int(attachment or 0)
            or str(associated_guid or "").strip()
            or int(item_type or 0) != 0
            or str(balloon_bundle_id or "").strip()
            or "\ufffc" in body
        ):
            return "unsupported", ""
        if not body or len(body) > MAX_BODY_CHARS:
            return "unsupported", ""
        return "text", body

    def messages_after(
        self,
        selected: dict[str, Chat],
        cursors: dict[str, int],
    ) -> dict[str, list[Message]]:
        database = self._connect()
        try:
            schema = self._columns(database, "message")
            attachment = "m.cache_has_attachments" if "cache_has_attachments" in schema else "0"
            associated = "m.associated_message_guid" if "associated_message_guid" in schema else "NULL"
            item_type = "m.item_type" if "item_type" in schema else "0"
            balloon = "m.balloon_bundle_id" if "balloon_bundle_id" in schema else "NULL"
            result: dict[str, list[Message]] = {chat_id: [] for chat_id in selected}
            for chat_id, chat in selected.items():
                rows = database.execute(
                    "SELECT m.ROWID AS sequence,m.guid,m.text,m.is_from_me,"
                    f"{attachment} AS has_attachment,{associated} AS associated_guid,"
                    f"{item_type} AS item_type,{balloon} AS balloon_bundle_id "
                    "FROM chat_message_join cmj JOIN message m ON m.ROWID=cmj.message_id "
                    "WHERE cmj.chat_id=? AND m.ROWID>? ORDER BY m.ROWID",
                    (chat.rowid, cursors.get(chat_id, -1)),
                ).fetchall()
                for row in rows:
                    kind, text = self._kind(
                        row["text"],
                        row["has_attachment"],
                        row["associated_guid"],
                        row["item_type"],
                        row["balloon_bundle_id"],
                    )
                    raw_guid = str(row["guid"] or "").strip()
                    if not raw_guid:
                        raw_guid = f"{chat_id}:row:{int(row['sequence'])}"
                    result[chat_id].append(
                        Message(
                            guid="messages-event:" + digest(raw_guid),
                            chat_id=chat_id,
                            sequence=int(row["sequence"]),
                            direction="outbound" if int(row["is_from_me"] or 0) else "inbound",
                            kind=kind,
                            text=text,
                        )
                    )
            return result
        except sqlite3.DatabaseError as exc:
            raise AutopilotError("messages_database_error", "Messages events could not be read") from exc
        finally:
            database.close()

    def recent_context(self, chat: Chat, *, through: int, limit: int) -> list[Message]:
        database = self._connect()
        try:
            schema = self._columns(database, "message")
            attachment = "m.cache_has_attachments" if "cache_has_attachments" in schema else "0"
            associated = "m.associated_message_guid" if "associated_message_guid" in schema else "NULL"
            item_type = "m.item_type" if "item_type" in schema else "0"
            balloon = "m.balloon_bundle_id" if "balloon_bundle_id" in schema else "NULL"
            rows = database.execute(
                "SELECT m.ROWID AS sequence,m.guid,m.text,m.is_from_me,"
                f"{attachment} AS has_attachment,{associated} AS associated_guid,"
                f"{item_type} AS item_type,{balloon} AS balloon_bundle_id "
                "FROM chat_message_join cmj JOIN message m ON m.ROWID=cmj.message_id "
                "WHERE cmj.chat_id=? AND m.ROWID<=? ORDER BY m.ROWID DESC LIMIT ?",
                (chat.rowid, through, limit * 3),
            ).fetchall()
            messages: list[Message] = []
            for row in reversed(rows):
                kind, text = self._kind(
                    row["text"],
                    row["has_attachment"],
                    row["associated_guid"],
                    row["item_type"],
                    row["balloon_bundle_id"],
                )
                if kind != "text":
                    continue
                raw_guid = str(row["guid"] or "").strip() or f"{chat.chat_id}:row:{int(row['sequence'])}"
                messages.append(
                    Message(
                        guid="messages-event:" + digest(raw_guid),
                        chat_id=chat.chat_id,
                        sequence=int(row["sequence"]),
                        direction="outbound" if int(row["is_from_me"] or 0) else "inbound",
                        kind="text",
                        text=text,
                    )
                )
            return messages[-limit:]
        except sqlite3.DatabaseError as exc:
            raise AutopilotError("messages_database_error", "Messages context could not be read") from exc
        finally:
            database.close()

    def watch_paths(self) -> list[Path]:
        return [self.path, Path(str(self.path) + "-wal"), Path(str(self.path) + "-shm"), self.path.parent]


class State:
    def __init__(self, paths: Paths, *, create: bool = True) -> None:
        self.paths = paths
        if create:
            ensure_private_root(paths.root)
        elif not paths.database.exists():
            raise AutopilotError("not_initialized", "Autopilot has not been configured")
        existed = paths.database.exists()
        if existed:
            info = paths.database.lstat()
            if (
                stat.S_ISLNK(info.st_mode)
                or not stat.S_ISREG(info.st_mode)
                or info.st_uid != os.getuid()
                or stat.S_IMODE(info.st_mode) & 0o077
            ):
                raise AutopilotError("unsafe_state", "state database must be private and owned by you")
        self.database = sqlite3.connect(paths.database, timeout=5, isolation_level=None)
        if not existed:
            os.chmod(paths.database, 0o600)
        self.database.row_factory = sqlite3.Row
        if existed:
            tables = {
                str(row[0])
                for row in self.database.execute(
                    "SELECT name FROM sqlite_master WHERE type='table'"
                )
            }
            if "settings" not in tables:
                self.database.close()
                raise AutopilotError(
                    "unsupported_state",
                    "legacy prototype state is intentionally not reused; select a fresh private state directory",
                )
        self.database.execute("PRAGMA journal_mode=WAL")
        self.database.execute("PRAGMA synchronous=FULL")
        self.database.execute("PRAGMA foreign_keys=ON")
        if not existed and create:
            self._create()
        self._validate()

    def _create(self) -> None:
        self.database.executescript(
            """
            CREATE TABLE IF NOT EXISTS settings(
              key TEXT PRIMARY KEY,
              value TEXT NOT NULL
            );
            CREATE TABLE IF NOT EXISTS chats(
              chat_id TEXT PRIMARY KEY,
              kind TEXT NOT NULL,
              participants_hash TEXT NOT NULL,
              generation INTEGER NOT NULL,
              cursor INTEGER,
              paused_reason TEXT NOT NULL DEFAULT ''
            );
            CREATE TABLE IF NOT EXISTS events(
              message_guid TEXT PRIMARY KEY,
              chat_id TEXT NOT NULL,
              sequence INTEGER NOT NULL,
              status TEXT NOT NULL,
              reason TEXT NOT NULL DEFAULT '',
              updated_at REAL NOT NULL
            );
            CREATE INDEX IF NOT EXISTS events_chat_sequence
              ON events(chat_id,sequence);
            """
        )
        defaults = {
            "schema_version": str(SCHEMA_VERSION),
            "generation": "0",
            "paused": "1",
            "pause_reason": "not_configured",
            "stop_requested": "0",
            "mode": "stopped",
            "runtime_health": "stopped",
            "last_error": "",
            "messages_db": "",
            "poll_seconds": str(DEFAULT_POLL_SECONDS),
        }
        self.database.executemany(
            "INSERT OR IGNORE INTO settings(key,value) VALUES(?,?)",
            defaults.items(),
        )

    def _validate(self) -> None:
        version = self.get("schema_version")
        if version != str(SCHEMA_VERSION):
            raise AutopilotError(
                "unsupported_state", "controller state belongs to a different implementation; review before replacing it"
            )

    def close(self) -> None:
        self.database.close()

    @contextmanager
    def transaction(self) -> Any:
        self.database.execute("BEGIN IMMEDIATE")
        try:
            yield
        except BaseException:
            self.database.execute("ROLLBACK")
            raise
        else:
            self.database.execute("COMMIT")

    def get(self, key: str, default: str = "") -> str:
        row = self.database.execute("SELECT value FROM settings WHERE key=?", (key,)).fetchone()
        return default if row is None else str(row[0])

    def set(self, key: str, value: Any) -> None:
        self.database.execute(
            "INSERT INTO settings(key,value) VALUES(?,?) "
            "ON CONFLICT(key) DO UPDATE SET value=excluded.value",
            (key, str(value)),
        )

    def set_many(self, values: dict[str, Any]) -> None:
        with self.transaction():
            for key, value in values.items():
                self.set(key, value)

    def contract(self) -> dict[str, Any] | None:
        raw = self.get("contract")
        return None if not raw else json.loads(raw)

    def scope(self) -> dict[str, dict[str, str]]:
        contract = self.contract()
        if contract is None:
            return {}
        return {item["id"]: item for item in contract["included_chats"]}

    def configure(self, contract: dict[str, Any]) -> tuple[str, bool]:
        serialized = compact_json(contract)
        contract_hash = digest(serialized)
        changed = contract_hash != self.get("contract_hash")
        if not changed:
            return contract_hash, False
        generation = int(self.get("generation", "0")) + 1
        with self.transaction():
            self.set("contract", serialized)
            self.set("contract_hash", contract_hash)
            self.set("generation", generation)
            self.set("paused", "1")
            self.set("pause_reason", "configuration_changed")
            self.database.execute("DELETE FROM chats")
            self.database.executemany(
                "INSERT INTO chats(chat_id,kind,participants_hash,generation,cursor,paused_reason) "
                "VALUES(?,?,?,?,NULL,'')",
                [
                    (
                        item["id"],
                        item["kind"],
                        item["participants_hash"],
                        generation,
                    )
                    for item in contract["included_chats"]
                ],
            )
        return contract_hash, True

    def reset_boundaries(self, selected: dict[str, Chat]) -> None:
        with self.transaction():
            self.database.execute("DELETE FROM events WHERE status='pending'")
            for chat_id, chat in selected.items():
                self.database.execute(
                    "UPDATE chats SET cursor=? WHERE chat_id=?",
                    (chat.last_sequence, chat_id),
                )

    def cursors(self) -> dict[str, int]:
        rows = self.database.execute("SELECT chat_id,cursor FROM chats").fetchall()
        return {str(row["chat_id"]): int(row["cursor"] if row["cursor"] is not None else -1) for row in rows}

    def cursor(self, chat_id: str) -> int:
        row = self.database.execute("SELECT cursor FROM chats WHERE chat_id=?", (chat_id,)).fetchone()
        if row is None:
            raise AutopilotError("scope_missing", "chat is not configured")
        return int(row[0] if row[0] is not None else -1)

    def advance(self, chat_id: str, sequence: int) -> None:
        self.database.execute(
            "UPDATE chats SET cursor=MAX(COALESCE(cursor,-1),?) WHERE chat_id=?",
            (sequence, chat_id),
        )

    def event_status(self, guid: str) -> str:
        row = self.database.execute("SELECT status FROM events WHERE message_guid=?", (guid,)).fetchone()
        return "" if row is None else str(row[0])

    def record(self, message: Message, status: str, reason: str = "") -> None:
        self.database.execute(
            "INSERT INTO events(message_guid,chat_id,sequence,status,reason,updated_at) "
            "VALUES(?,?,?,?,?,?) ON CONFLICT(message_guid) DO UPDATE SET "
            "status=excluded.status,reason=excluded.reason,updated_at=excluded.updated_at",
            (message.guid, message.chat_id, message.sequence, status, reason[:MAX_REASON_CHARS], time.time()),
        )

    def terminal(self, message: Message, status: str, reason: str = "") -> None:
        with self.transaction():
            self.record(message, status, reason)
            self.advance(message.chat_id, message.sequence)

    def mark_attempted(self, message: Message) -> None:
        with self.transaction():
            self.record(message, "attempted")
            self.advance(message.chat_id, message.sequence)

    def prune_events(self, chat_id: str) -> None:
        self.database.execute(
            "DELETE FROM events WHERE chat_id=? AND status NOT IN ('attempted','uncertain') "
            "AND message_guid NOT IN (SELECT message_guid FROM events WHERE chat_id=? "
            "ORDER BY sequence DESC LIMIT ?)",
            (chat_id, chat_id, MAX_RETAINED_EVENTS_PER_CHAT),
        )

    def pause_chat(self, chat_id: str, reason: str) -> None:
        self.database.execute(
            "UPDATE chats SET paused_reason=? WHERE chat_id=?", (reason[:MAX_REASON_CHARS], chat_id)
        )

    def chat_pause(self, chat_id: str) -> str:
        row = self.database.execute("SELECT paused_reason FROM chats WHERE chat_id=?", (chat_id,)).fetchone()
        return "scope_missing" if row is None else str(row[0])

    def reconcile_attempts(self) -> int:
        rows = self.database.execute(
            "SELECT DISTINCT chat_id FROM events WHERE status='attempted'"
        ).fetchall()
        with self.transaction():
            for row in rows:
                self.pause_chat(str(row[0]), "uncertain_send")
                self.database.execute(
                    "UPDATE events SET status='uncertain',reason='controller stopped during send',updated_at=? "
                    "WHERE chat_id=? AND status='attempted'",
                    (time.time(), str(row[0])),
                )
        return len(rows)

    def set_global_pause(self, paused: bool, reason: str = "") -> None:
        self.set_many({"paused": "1" if paused else "0", "pause_reason": reason})

    def status(self) -> dict[str, Any]:
        chats = self.database.execute(
            "SELECT chat_id,kind,paused_reason FROM chats ORDER BY chat_id"
        ).fetchall()
        events = self.database.execute(
            "SELECT status,COUNT(*) AS count FROM events GROUP BY status"
        ).fetchall()
        return {
            "configured": self.contract() is not None,
            "contract_hash": self.get("contract_hash"),
            "paused": self.get("paused", "1") == "1",
            "pause_reason": self.get("pause_reason"),
            "mode": self.get("mode", "stopped"),
            "runtime_health": self.get("runtime_health", "stopped"),
            "last_error": self.get("last_error"),
            "messages_db": self.get("messages_db"),
            "poll_seconds": float(self.get("poll_seconds", str(DEFAULT_POLL_SECONDS))),
            "chats": [
                {
                    "id": str(row["chat_id"]),
                    "kind": str(row["kind"]),
                    "paused_reason": str(row["paused_reason"]),
                }
                for row in chats
            ],
            "event_counts": {str(row["status"]): int(row["count"]) for row in events},
        }


class DecisionRuntime(Protocol):
    def start(self) -> None: ...
    def decide(
        self,
        chat_id: str,
        messages: list[Message],
        contract: dict[str, Any],
        *,
        initial: bool,
    ) -> dict[str, str]: ...
    def invalidate(self, chat_id: str) -> None: ...
    def close(self) -> None: ...


class Sender(Protocol):
    def send(self, chat_guid: str, text: str) -> None: ...


class CodexRuntime:
    """One constrained app-server process with one ephemeral thread per chat."""

    def __init__(self, binary: Path, *, timeout: float = DEFAULT_CODEX_TIMEOUT) -> None:
        self.binary = binary
        self.timeout = timeout
        prompt_path, schema_path = asset_paths()
        try:
            self.prompt = prompt_path.read_text(encoding="utf-8")
            self.schema = json.loads(schema_path.read_text(encoding="utf-8"))
        except (OSError, json.JSONDecodeError) as exc:
            raise AutopilotError("invalid_assets", "runtime assets are missing or invalid") from exc
        self.process: subprocess.Popen[str] | None = None
        self.runtime_dir: tempfile.TemporaryDirectory[str] | None = None
        self.condition = threading.Condition()
        self.write_lock = threading.Lock()
        self.responses: dict[int, dict[str, Any]] = {}
        self.notifications: deque[dict[str, Any]] = deque()
        self.error = ""
        self.next_id = 1
        self.threads: dict[str, str] = {}
        self.readers: list[threading.Thread] = []
        self.cancel_check: Any = None

    def _command(self) -> list[str]:
        command = [str(self.binary), "--strict-config"]
        for override in CODEX_OVERRIDES:
            command.extend(["-c", override])
        return command + ["app-server", "--listen", "stdio://"]

    def start(self) -> None:
        if self.process is not None and self.process.poll() is None:
            return
        if self.process is not None:
            raise RuntimeFailure("codex_runtime_exited", "Codex runtime exited")
        self.runtime_dir = tempfile.TemporaryDirectory(prefix="imessage-autopilot-codex-")
        root = Path(self.runtime_dir.name)
        sqlite_home = root / "sqlite"
        sqlite_home.mkdir(mode=0o700)
        environment = codex_environment(sqlite_home=sqlite_home)
        try:
            self.process = subprocess.Popen(
                self._command(),
                stdin=subprocess.PIPE,
                stdout=subprocess.PIPE,
                stderr=subprocess.PIPE,
                text=True,
                cwd=root,
                env=environment,
                start_new_session=True,
                close_fds=True,
                bufsize=1,
            )
        except OSError as exc:
            self.close()
            raise RuntimeFailure("codex_runtime_launch_failed", "Codex runtime could not start") from exc
        assert self.process.stdout is not None and self.process.stderr is not None
        stdout = threading.Thread(target=self._read_stdout, args=(self.process.stdout,), daemon=True)
        stderr = threading.Thread(target=self._drain, args=(self.process.stderr,), daemon=True)
        self.readers = [stdout, stderr]
        stdout.start()
        stderr.start()
        try:
            result = self._request(
                "initialize",
                {
                    "clientInfo": {
                        "name": "imessage_autopilot",
                        "title": "iMessage Autopilot",
                        "version": VERSION,
                    },
                    "capabilities": {
                        "experimentalApi": False,
                        "optOutNotificationMethods": CODEX_NOTIFICATION_OPT_OUTS,
                    },
                },
            )
        except RuntimeFailure:
            self.close()
            raise
        if not isinstance(result.get("userAgent"), str):
            self.close()
            raise RuntimeFailure("codex_protocol_error", "Codex app-server protocol is incompatible")
        self._send({"method": "initialized", "params": {}})

    @staticmethod
    def _drain(stream: Any) -> None:
        try:
            for _ in stream:
                pass
        except (OSError, ValueError):
            pass

    def _read_stdout(self, stream: Any) -> None:
        try:
            for line in stream:
                if len(line.encode("utf-8")) > MAX_PROTOCOL_BYTES:
                    self._fail("codex_runtime_output_too_large")
                    return
                try:
                    message = json.loads(line)
                except json.JSONDecodeError:
                    self._fail("codex_runtime_invalid_stream")
                    return
                if not isinstance(message, dict):
                    self._fail("codex_runtime_invalid_stream")
                    return
                if "method" in message and "id" in message:
                    try:
                        self._send(
                            {
                                "id": message["id"],
                                "error": {"code": -32601, "message": "server requests are disabled"},
                            }
                        )
                    finally:
                        self._fail("codex_runtime_server_request")
                    return
                with self.condition:
                    if "id" in message:
                        identifier = message["id"]
                        if not isinstance(identifier, int) or isinstance(identifier, bool):
                            self.error = "codex_runtime_invalid_stream"
                        else:
                            self.responses[identifier] = message
                    elif isinstance(message.get("method"), str):
                        if len(self.notifications) >= MAX_NOTIFICATIONS:
                            self.error = "codex_runtime_notification_overflow"
                        else:
                            self.notifications.append(message)
                    else:
                        self.error = "codex_runtime_invalid_stream"
                    self.condition.notify_all()
        except (OSError, ValueError):
            pass
        finally:
            if self.process is not None and self.process.poll() is not None:
                self._fail("codex_runtime_exited")

    def _fail(self, reason: str) -> None:
        with self.condition:
            if not self.error:
                self.error = reason
            self.condition.notify_all()

    def _send(self, message: dict[str, Any]) -> None:
        if self.process is None or self.process.stdin is None or self.process.poll() is not None:
            raise RuntimeFailure("codex_runtime_exited", "Codex runtime is not available")
        try:
            with self.write_lock:
                self.process.stdin.write(compact_json(message) + "\n")
                self.process.stdin.flush()
        except (BrokenPipeError, OSError) as exc:
            raise RuntimeFailure("codex_runtime_exited", "Codex runtime exited") from exc

    def _wait(self, predicate: Any, deadline: float) -> Any:
        with self.condition:
            while True:
                if self.cancel_check is not None and self.cancel_check():
                    raise RuntimeFailure("codex_cancelled", "Codex decision was cancelled")
                if self.error:
                    raise RuntimeFailure(self.error, "Codex runtime failed")
                value = predicate()
                if value is not None:
                    return value
                if self.process is None or self.process.poll() is not None:
                    raise RuntimeFailure("codex_runtime_exited", "Codex runtime exited")
                remaining = deadline - time.monotonic()
                if remaining <= 0:
                    raise RuntimeFailure("codex_runtime_timeout", "Codex runtime timed out")
                self.condition.wait(timeout=min(0.1, remaining))

    def _request(self, method: str, params: dict[str, Any]) -> dict[str, Any]:
        identifier = self.next_id
        self.next_id += 1
        self._send({"id": identifier, "method": method, "params": params})
        deadline = time.monotonic() + self.timeout
        response = self._wait(lambda: self.responses.pop(identifier, None), deadline)
        if "error" in response or not isinstance(response.get("result"), dict):
            raise RuntimeFailure("codex_protocol_error", "Codex app-server request failed")
        return response["result"]

    def _thread(self, chat_id: str) -> tuple[str, bool]:
        existing = self.threads.get(chat_id)
        if existing:
            return existing, False
        result = self._request(
            "thread/start",
            {
                "cwd": self.runtime_dir.name if self.runtime_dir else tempfile.gettempdir(),
                "approvalPolicy": "never",
                "sandbox": "read-only",
                "baseInstructions": self.prompt,
                "developerInstructions": (
                    "Draft for exactly one isolated Messages chat. Never call tools, browse, "
                    "read files, run commands, access apps, or perform external actions."
                ),
                "ephemeral": True,
                "modelProvider": "openai",
            },
        )
        thread = result.get("thread")
        if not isinstance(thread, dict) or not isinstance(thread.get("id"), str):
            raise RuntimeFailure("codex_protocol_error", "Codex thread creation failed")
        thread_id = thread["id"]
        self.threads[chat_id] = thread_id
        return thread_id, True

    @staticmethod
    def _validate_result(value: Any) -> dict[str, str]:
        if not isinstance(value, dict) or set(value) != {"action", "reply", "reason"}:
            raise RuntimeFailure("codex_invalid_output", "Codex returned an invalid decision")
        action = value.get("action")
        reply = value.get("reply")
        reason = value.get("reason")
        if action not in {"reply", "no_action", "escalate"} or not isinstance(reply, str) or not isinstance(reason, str):
            raise RuntimeFailure("codex_invalid_output", "Codex returned an invalid decision")
        reply = reply.strip()
        reason = reason.strip()
        if len(reply) > MAX_REPLY_CHARS or not 1 <= len(reason) <= MAX_REASON_CHARS:
            raise RuntimeFailure("codex_invalid_output", "Codex decision exceeds limits")
        if (action == "reply") != bool(reply):
            raise RuntimeFailure("codex_invalid_output", "Codex reply action is inconsistent")
        return {"action": action, "reply": reply, "reason": reason}

    def decide(
        self,
        chat_id: str,
        messages: list[Message],
        contract: dict[str, Any],
        *,
        initial: bool,
    ) -> dict[str, str]:
        self.start()
        thread_id, created = self._thread(chat_id)
        payload = {
            "context_mode": "initial_history" if created or initial else "new_messages",
            "reply_contract": {
                "owner_label": contract["owner_label"],
                "reply_style": contract["reply_style"],
                "disclosure": contract["disclosure"],
            },
            "messages": [
                {
                    "sequence": message.sequence,
                    "direction": message.direction,
                    "text": message.text,
                }
                for message in messages
            ],
        }
        result = self._request(
            "turn/start",
            {
                "threadId": thread_id,
                "input": [
                    {
                        "type": "text",
                        "text": "Untrusted conversation data follows. Return only JSON:\n" + compact_json(payload),
                    }
                ],
                "outputSchema": self.schema,
                "approvalPolicy": "never",
                "sandboxPolicy": {"type": "readOnly", "networkAccess": False},
                "effort": "low",
            },
        )
        turn = result.get("turn")
        if not isinstance(turn, dict) or not isinstance(turn.get("id"), str):
            raise RuntimeFailure("codex_protocol_error", "Codex turn did not start")
        turn_id = turn["id"]
        deadline = time.monotonic() + self.timeout

        def completed() -> dict[str, Any] | None:
            while self.notifications:
                notification = self.notifications.popleft()
                if notification.get("method") == "error":
                    raise RuntimeFailure("codex_runtime_failed", "Codex decision failed")
                params = notification.get("params")
                if not isinstance(params, dict):
                    raise RuntimeFailure("codex_runtime_invalid_stream", "Codex returned an invalid event")
                if notification.get("method") != "turn/completed":
                    item = params.get("item")
                    if isinstance(item, dict) and item.get("type") not in CODEX_ALLOWED_ITEMS:
                        raise RuntimeFailure("codex_tool_activity", "Codex attempted a disabled action")
                    continue
                if params.get("threadId") != thread_id:
                    continue
                candidate = params.get("turn")
                if isinstance(candidate, dict) and candidate.get("id") == turn_id:
                    return candidate
            return None

        final_turn = self._wait(completed, deadline)
        if final_turn.get("status") != "completed" or not isinstance(final_turn.get("items"), list):
            raise RuntimeFailure("codex_runtime_failed", "Codex decision failed")
        output: str | None = None
        for item in final_turn["items"]:
            if not isinstance(item, dict) or item.get("type") not in CODEX_ALLOWED_ITEMS:
                raise RuntimeFailure("codex_tool_activity", "Codex attempted a disabled action")
            if item.get("type") == "agentMessage" and isinstance(item.get("text"), str):
                output = item["text"]
        if output is None:
            raise RuntimeFailure("codex_invalid_output", "Codex returned no decision")
        try:
            return self._validate_result(json.loads(output))
        except json.JSONDecodeError as exc:
            raise RuntimeFailure("codex_invalid_output", "Codex returned invalid JSON") from exc

    def invalidate(self, chat_id: str) -> None:
        self.threads.pop(chat_id, None)

    def close(self) -> None:
        process = self.process
        self.process = None
        self.threads.clear()
        with self.condition:
            self.error = ""
            self.responses.clear()
            self.notifications.clear()
            self.condition.notify_all()
        if process is not None and process.poll() is None:
            try:
                os.killpg(process.pid, signal.SIGTERM)
                process.wait(timeout=2)
            except (ProcessLookupError, OSError, subprocess.TimeoutExpired):
                try:
                    os.killpg(process.pid, signal.SIGKILL)
                except (ProcessLookupError, OSError):
                    pass
                try:
                    process.wait(timeout=2)
                except (OSError, subprocess.TimeoutExpired):
                    pass
        if process is not None:
            for stream in (process.stdin, process.stdout, process.stderr):
                if stream is not None:
                    try:
                        stream.close()
                    except OSError:
                        pass
        for reader in self.readers:
            if reader is not threading.current_thread():
                reader.join(timeout=0.5)
        self.readers = []
        if self.runtime_dir is not None:
            try:
                self.runtime_dir.cleanup()
            except OSError:
                pass
            self.runtime_dir = None


class AppleScriptSender:
    """Poke-derived fixed AppleScript program; all user data is passed through argv."""

    PROGRAM = [
        "on run argv",
        "set chatId to item 1 of argv",
        "set bodyText to item 2 of argv",
        'tell application "Messages"',
        "send bodyText to chat id chatId",
        "end tell",
        "end run",
    ]

    def __init__(self, binary: Path) -> None:
        self.binary = binary

    def send(self, chat_guid: str, text: str) -> None:
        command = [str(self.binary)]
        for line in self.PROGRAM:
            command.extend(["-e", line])
        command.extend(["--", chat_guid, text])
        try:
            result = subprocess.run(
                command,
                stdin=subprocess.DEVNULL,
                stdout=subprocess.DEVNULL,
                stderr=subprocess.PIPE,
                text=True,
                timeout=30,
                check=False,
            )
        except (OSError, subprocess.TimeoutExpired) as exc:
            raise AutopilotError("send_uncertain", "Messages send outcome is uncertain") from exc
        if result.returncode != 0:
            raise AutopilotError("send_uncertain", "Messages rejected or did not confirm the send command")


class Watcher:
    """Best-effort vnode wakeups; timeout polling remains authoritative."""

    def __init__(self, paths: list[Path]) -> None:
        self.paths = paths
        self.kqueue: Any = None
        self.descriptors: list[int] = []
        self._setup()

    def _setup(self) -> None:
        if not hasattr(select, "kqueue"):
            return
        self._teardown()
        try:
            self.kqueue = select.kqueue()
            flags = os.O_RDONLY | getattr(os, "O_CLOEXEC", 0)
            for path in self.paths:
                if not path.exists():
                    continue
                descriptor = os.open(path, flags)
                self.descriptors.append(descriptor)
                event = select.kevent(
                    descriptor,
                    filter=select.KQ_FILTER_VNODE,
                    flags=select.KQ_EV_ADD | select.KQ_EV_CLEAR,
                    fflags=(
                        select.KQ_NOTE_WRITE
                        | select.KQ_NOTE_EXTEND
                        | select.KQ_NOTE_RENAME
                        | select.KQ_NOTE_DELETE
                    ),
                )
                self.kqueue.control([event], 0, 0)
        except (OSError, ValueError):
            self._teardown()

    def wait(self, timeout: float) -> None:
        if self.kqueue is None:
            time.sleep(timeout)
            return
        try:
            events = self.kqueue.control(None, 1, timeout)
        except (OSError, ValueError):
            self._setup()
            time.sleep(timeout)
            return
        if events:
            self._setup()

    def _teardown(self) -> None:
        if self.kqueue is not None:
            try:
                self.kqueue.close()
            except OSError:
                pass
            self.kqueue = None
        for descriptor in self.descriptors:
            try:
                os.close(descriptor)
            except OSError:
                pass
        self.descriptors = []

    def close(self) -> None:
        self._teardown()


class Controller:
    def __init__(
        self,
        paths: Paths,
        state: State,
        source: MessagesSource,
        runtime: DecisionRuntime,
        sender: Sender,
        *,
        poll_seconds: float,
        context_messages: int = DEFAULT_CONTEXT_MESSAGES,
        settle_seconds: float = DEFAULT_SETTLE_SECONDS,
        mode: str = "foreground",
    ) -> None:
        self.paths = paths
        self.state = state
        self.source = source
        self.runtime = runtime
        self.sender = sender
        self.poll_seconds = poll_seconds
        self.context_messages = context_messages
        self.settle_seconds = settle_seconds
        self.mode = mode
        self.lock_handle: Any = None
        if isinstance(runtime, CodexRuntime):
            runtime.cancel_check = lambda: (
                self.state.get("stop_requested") == "1"
                or self.state.get("paused") == "1"
            )

    def _lock(self) -> None:
        descriptor = open_private(self.paths.lock, os.O_RDWR | os.O_CREAT)
        self.lock_handle = os.fdopen(descriptor, "r+")
        try:
            fcntl.flock(self.lock_handle.fileno(), fcntl.LOCK_EX | fcntl.LOCK_NB)
        except BlockingIOError as exc:
            self.lock_handle.close()
            self.lock_handle = None
            raise AutopilotError("already_running", "another Autopilot controller is running") from exc
        self.lock_handle.seek(0)
        self.lock_handle.truncate()
        self.lock_handle.write(str(os.getpid()))
        self.lock_handle.flush()

    def _prepare(self) -> dict[str, Chat]:
        contract = self.state.contract()
        if contract is None:
            raise AutopilotError("not_configured", "configure Autopilot before running it")
        self.source.validate()
        self.state.reconcile_attempts()
        selected = self.source.selected(self.state.scope())
        self.state.reset_boundaries(selected)
        self.state.set_many(
            {
                "stop_requested": "0",
                "mode": self.mode,
                "runtime_health": "paused" if self.state.get("paused") == "1" else "starting",
                "messages_db": str(self.source.path),
                "poll_seconds": self.poll_seconds,
                "last_error": "",
            }
        )
        return selected

    def run(self, *, max_cycles: int | None = None) -> int:
        self._lock()
        watcher: Watcher | None = None
        prepared = False
        try:
            selected = self._prepare()
            prepared = True
            generation = self.state.get("generation")
            was_paused = self.state.get("paused") == "1"
            watcher = Watcher(self.source.watch_paths())
            cycles = 0
            emit(
                {
                    "ok": True,
                    "event": "controller_ready",
                    "mode": self.mode,
                    "paused": self.state.get("paused") == "1",
                    "poll_seconds": self.poll_seconds,
                    "chat_count": len(selected),
                }
            )
            while self.state.get("stop_requested") != "1":
                if self.state.get("paused") == "1":
                    self.runtime.close()
                    self.state.set("runtime_health", "paused")
                    was_paused = True
                else:
                    try:
                        if was_paused or self.state.get("generation") != generation:
                            self.runtime.close()
                            selected = self.source.selected(self.state.scope())
                            self.state.reset_boundaries(selected)
                            generation = self.state.get("generation")
                            was_paused = False
                        self.runtime.start()
                        self.state.set("runtime_health", "running")
                        self.scan(selected)
                    except RuntimeFailure as exc:
                        self.runtime.close()
                        if self.state.get("stop_requested") != "1" and self.state.get("paused") != "1":
                            self.state.set_many(
                                {
                                    "paused": "1",
                                    "pause_reason": "codex_runtime_failure",
                                    "runtime_health": "failed",
                                    "last_error": exc.code,
                                }
                            )
                            was_paused = True
                    except AutopilotError as exc:
                        self.runtime.close()
                        self.state.set_many(
                            {
                                "paused": "1",
                                "pause_reason": exc.code,
                                "runtime_health": "failed",
                                "last_error": exc.code,
                            }
                        )
                        was_paused = True
                cycles += 1
                if max_cycles is not None and cycles >= max_cycles:
                    break
                watcher.wait(self.poll_seconds)
            return 0
        finally:
            if watcher is not None:
                watcher.close()
            self.runtime.close()
            if prepared:
                self.state.set_many(
                    {"mode": "stopped", "runtime_health": "stopped", "stop_requested": "0"}
                )
            if self.lock_handle is not None:
                self.lock_handle.close()
                self.lock_handle = None

    def scan(self, selected: dict[str, Chat]) -> None:
        self.source.validate_scope(selected)
        cursors = self.state.cursors()
        batches = self.source.messages_after(selected, cursors)
        if self.settle_seconds > 0 and any(batches.values()):
            time.sleep(self.settle_seconds)
            if self.state.get("paused") == "1" or self.state.get("stop_requested") == "1":
                return
            self.source.validate_scope(selected)
            batches = self.source.messages_after(selected, cursors)
        for chat_id, messages in batches.items():
            if not messages or self.state.chat_pause(chat_id):
                continue
            self._process_chat(selected[chat_id], cursors[chat_id], messages)

    def _process_chat(self, chat: Chat, prior_cursor: int, messages: list[Message]) -> None:
        last = messages[-1]
        if last.direction == "outbound":
            self.state.terminal(last, "ignored", "human_or_external_outbound")
            self.state.prune_events(chat.chat_id)
            self.runtime.invalidate(chat.chat_id)
            return
        after_outbound: list[Message] = []
        for message in messages:
            if message.direction == "outbound":
                after_outbound = []
            else:
                after_outbound.append(message)
        if not after_outbound:
            self.state.advance(chat.chat_id, last.sequence)
            return
        candidate = after_outbound[-1]
        existing = self.state.event_status(candidate.guid)
        if existing in {"sent", "ignored", "escalated", "uncertain", "attempted"}:
            self.state.advance(chat.chat_id, candidate.sequence)
            self.state.prune_events(chat.chat_id)
            return
        if any(message.kind != "text" for message in after_outbound):
            self.state.terminal(candidate, "escalated", "unsupported_content")
            self.state.prune_events(chat.chat_id)
            self.runtime.invalidate(chat.chat_id)
            return
        contract = self.state.contract()
        if contract is None:
            raise AutopilotError("not_configured", "configuration disappeared")
        initial = chat.chat_id not in getattr(self.runtime, "threads", {})
        decision_messages = after_outbound
        if initial:
            decision_messages = self.source.recent_context(
                chat, through=candidate.sequence, limit=self.context_messages
            )
        self.state.record(candidate, "pending")
        decision = self.runtime.decide(
            chat.chat_id,
            decision_messages,
            contract,
            initial=initial,
        )
        action = decision["action"]
        if action == "no_action":
            self.state.terminal(candidate, "ignored", "model_no_action")
            self.state.prune_events(chat.chat_id)
            return
        if action == "escalate":
            self.state.terminal(candidate, "escalated", "model_escalation")
            self.state.prune_events(chat.chat_id)
            return
        current = self.source.messages_after(
            {chat.chat_id: chat}, {chat.chat_id: prior_cursor}
        )[chat.chat_id]
        if not current or current[-1].guid != candidate.guid or current[-1].direction != "inbound":
            self.runtime.invalidate(chat.chat_id)
            return
        if self.state.get("paused") == "1" or self.state.get("stop_requested") == "1":
            self.runtime.invalidate(chat.chat_id)
            return
        if self.state.get("contract_hash") != digest(compact_json(contract)):
            self.runtime.invalidate(chat.chat_id)
            return
        self.source.validate_scope({chat.chat_id: chat})
        self.state.mark_attempted(candidate)
        try:
            self.sender.send(chat.guid, decision["reply"])
        except AutopilotError as exc:
            self.state.record(candidate, "uncertain", exc.code)
            self.state.pause_chat(chat.chat_id, "uncertain_send")
            self.state.prune_events(chat.chat_id)
            self.runtime.invalidate(chat.chat_id)
            return
        self.state.record(candidate, "sent")
        self.state.prune_events(chat.chat_id)


def controller_running(paths: Paths) -> bool:
    if not paths.root.exists():
        return False
    ensure_private_root(paths.root)
    descriptor = open_private(paths.lock, os.O_RDWR | os.O_CREAT)
    try:
        try:
            fcntl.flock(descriptor, fcntl.LOCK_EX | fcntl.LOCK_NB)
        except BlockingIOError:
            return True
        return False
    finally:
        os.close(descriptor)


def osascript() -> Path:
    found = shutil.which("osascript")
    if sys.platform != "darwin" or not found:
        raise AutopilotError("osascript_unavailable", "osascript is unavailable")
    return Path(found)


def command_doctor(args: argparse.Namespace, paths: Paths) -> int:
    del args
    prompt, schema = asset_paths()
    codex = find_codex()
    checks = {
        "python_3_11": sys.version_info >= (3, 11),
        "macos": sys.platform == "darwin",
        "osascript": shutil.which("osascript") is not None,
        "codex_app_server": codex is not None and codex_app_server_available(codex),
        "runtime_prompt": prompt.is_file(),
        "reply_schema": schema.is_file(),
    }
    ensure_private_root(paths.root)
    checks["private_state"] = True
    ready = all(checks.values())
    emit(
        {
            "ok": ready,
            "checks": checks,
            "messages_accessed": False,
            "permissions_requested": False,
            "message_sent": False,
        }
    )
    return 0 if ready else 1


def command_preflight(args: argparse.Namespace, paths: Paths) -> int:
    del paths
    source = MessagesSource(Path(args.messages_db))
    source.validate()
    emit(
        {
            "ok": True,
            "path": str(source.path),
            "database_opened_read_only": True,
            "message_rows_read": False,
            "apple_events_invoked": False,
        }
    )
    return 0


def command_chats(args: argparse.Namespace, paths: Paths) -> int:
    del paths
    if not 1 <= args.limit <= 100:
        raise AutopilotError("invalid_value", "limit must be between 1 and 100")
    if len(args.search) > 200:
        raise AutopilotError("invalid_value", "search must be at most 200 characters")
    source = MessagesSource(Path(args.messages_db))
    source.validate()
    chats = source.list_chats(limit=args.limit, search=args.search)
    emit(
        {
            "ok": True,
            "count": len(chats),
            "chats": [
                {
                    "id": chat.chat_id,
                    "label": chat.label,
                    "kind": chat.kind,
                    "participants_hash": chat.participants_hash,
                    "participants": list(chat.participants),
                    "service": chat.service,
                    "last_sequence": chat.last_sequence,
                    "sendable": bool(chat.guid),
                }
                for chat in chats
            ],
            "message_bodies_read": False,
            "contacts_accessed": False,
        }
    )
    return 0


def command_configure(args: argparse.Namespace, paths: Paths) -> int:
    del args
    text = sys.stdin.read(262_145)
    if len(text) > 262_144:
        raise AutopilotError("invalid_contract", "contract is too large")
    try:
        contract = normalize_contract(json.loads(text))
    except json.JSONDecodeError as exc:
        raise AutopilotError("invalid_contract", "contract is not valid JSON") from exc
    state = State(paths)
    try:
        contract_hash, changed = state.configure(contract)
        paused = state.get("paused") == "1"
        pause_reason = state.get("pause_reason")
    finally:
        state.close()
    emit(
        {
            "ok": True,
            "contract_hash": contract_hash,
            "changed": changed,
            "paused": paused,
            "pause_reason": pause_reason,
        }
    )
    return 0


def command_status(args: argparse.Namespace, paths: Paths) -> int:
    del args
    if not paths.database.exists():
        emit({"ok": True, "configured": False, "running": False, "paused": True, "mode": "stopped"})
        return 0
    state = State(paths, create=False)
    try:
        snapshot = state.status()
    finally:
        state.close()
    snapshot.update({"ok": True, "running": controller_running(paths)})
    emit(snapshot)
    return 0


def command_pause(args: argparse.Namespace, paths: Paths) -> int:
    del args
    state = State(paths, create=False)
    try:
        state.set_global_pause(True, "user_paused")
    finally:
        state.close()
    emit({"ok": True, "paused": True, "running": controller_running(paths)})
    return 0


def command_resume(args: argparse.Namespace, paths: Paths) -> int:
    state = State(paths, create=False)
    try:
        if state.contract() is None:
            raise AutopilotError("not_configured", "configure Autopilot before resuming")
        if args.chat_id:
            chat_id = string_field(args.chat_id, "chat_id", maximum=128)
            previous = state.chat_pause(chat_id)
            if previous == "scope_missing":
                raise AutopilotError("scope_missing", "chat is not configured")
            state.pause_chat(chat_id, "")
            payload = {"ok": True, "chat_id": chat_id, "resumed": bool(previous)}
        else:
            state.set_global_pause(False, "")
            payload = {"ok": True, "paused": False}
    finally:
        state.close()
    payload["running"] = controller_running(paths)
    emit(payload)
    return 0


def command_stop(args: argparse.Namespace, paths: Paths) -> int:
    del args
    if not paths.database.exists() or not controller_running(paths):
        emit({"ok": True, "running": False})
        return 0
    state = State(paths, create=False)
    try:
        state.set("stop_requested", "1")
    finally:
        state.close()
    deadline = time.monotonic() + 35
    while time.monotonic() < deadline and controller_running(paths):
        time.sleep(0.05)
    if controller_running(paths):
        raise AutopilotError("stop_timeout", "controller did not stop", exit_code=1)
    emit({"ok": True, "running": False})
    return 0


def validate_runtime_values(args: argparse.Namespace) -> tuple[Path, float, float]:
    if not 2 <= args.poll_seconds <= 5:
        raise AutopilotError("invalid_value", "poll interval must be between 2 and 5 seconds")
    if not 5 <= args.codex_timeout <= 300:
        raise AutopilotError("invalid_value", "Codex timeout must be between 5 and 300 seconds")
    return Path(args.messages_db).expanduser().absolute(), args.poll_seconds, args.codex_timeout


def runtime_components(args: argparse.Namespace) -> tuple[MessagesSource, CodexRuntime, AppleScriptSender]:
    source_path, _poll_seconds, codex_timeout = validate_runtime_values(args)
    source = MessagesSource(source_path)
    source.validate()
    binary = find_codex()
    if binary is None or not codex_app_server_available(binary):
        raise AutopilotError("codex_unavailable", "Codex CLI app-server is unavailable")
    return source, CodexRuntime(binary, timeout=codex_timeout), AppleScriptSender(osascript())


def command_run(args: argparse.Namespace, paths: Paths) -> int:
    source, runtime, sender = runtime_components(args)
    state = State(paths)
    try:
        controller = Controller(
            paths,
            state,
            source,
            runtime,
            sender,
            poll_seconds=args.poll_seconds,
            mode="background" if args.background_child else "foreground",
        )
        return controller.run()
    finally:
        state.close()


def command_start(args: argparse.Namespace, paths: Paths) -> int:
    source_path, poll_seconds, _codex_timeout = validate_runtime_values(args)
    if controller_running(paths):
        running_state = State(paths, create=False)
        try:
            try:
                current_poll_seconds = float(running_state.get("poll_seconds"))
            except ValueError:
                current_poll_seconds = -1
            same_runtime = (
                running_state.get("messages_db") == str(source_path)
                and current_poll_seconds == poll_seconds
            )
        finally:
            running_state.close()
        if not same_runtime:
            raise AutopilotError(
                "running_configuration_mismatch",
                "the running controller uses a different Messages database or poll interval",
            )
        emit({"ok": True, "running": True, "already_running": True})
        return 0
    source, runtime, _sender = runtime_components(args)
    runtime.close()
    validation_state = State(paths, create=False)
    try:
        source.selected(validation_state.scope())
    finally:
        validation_state.close()
    state = State(paths, create=False)
    try:
        if state.contract() is None:
            raise AutopilotError("not_configured", "configure Autopilot before starting")
    finally:
        state.close()
    ensure_private_root(paths.root)
    descriptor = open_private(paths.log, os.O_WRONLY | os.O_CREAT | os.O_APPEND)
    if os.fstat(descriptor).st_size > 65_536:
        os.ftruncate(descriptor, 0)
    log = os.fdopen(descriptor, "a", encoding="utf-8")
    command = [
        sys.executable,
        "-B",
        str(Path(__file__).resolve()),
        "--state-dir",
        str(paths.root),
        "run",
        "--messages-db",
        str(source.path),
        "--poll-seconds",
        str(args.poll_seconds),
        "--codex-timeout",
        str(args.codex_timeout),
        "--background-child",
    ]
    process = subprocess.Popen(
        command,
        stdin=subprocess.DEVNULL,
        stdout=log,
        stderr=log,
        start_new_session=True,
        close_fds=True,
    )
    log.close()
    deadline = time.monotonic() + args.codex_timeout + 5
    while time.monotonic() < deadline:
        if controller_running(paths) and paths.database.exists():
            readiness = State(paths, create=False)
            try:
                ready = readiness.get("mode") == "background" and readiness.get("runtime_health") in {
                    "running",
                    "paused",
                }
            finally:
                readiness.close()
            if ready:
                emit({"ok": True, "running": True, "already_running": False, "pid": process.pid, "mode": "background"})
                return 0
        if process.poll() is not None:
            break
        time.sleep(0.05)
    if process.poll() is None:
        process.terminate()
        try:
            process.wait(timeout=2)
        except subprocess.TimeoutExpired:
            process.kill()
            try:
                process.wait(timeout=2)
            except subprocess.TimeoutExpired:
                pass
    raise AutopilotError("background_start_failed", "background controller did not start", exit_code=1)


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(description="Skill-scoped resident iMessage Autopilot controller")
    parser.add_argument("--state-dir", default=str(default_state_root()))
    subparsers = parser.add_subparsers(dest="command", required=True)

    subparsers.add_parser("doctor").set_defaults(handler=command_doctor)

    preflight = subparsers.add_parser("preflight")
    preflight.add_argument("--messages-db", required=True)
    preflight.set_defaults(handler=command_preflight)

    chats = subparsers.add_parser("chats")
    chats.add_argument("--messages-db", required=True)
    chats.add_argument("--limit", type=int, default=20)
    chats.add_argument("--search", default="")
    chats.set_defaults(handler=command_chats)

    configure = subparsers.add_parser("configure")
    configure.add_argument("--stdin-json", action="store_true", required=True)
    configure.set_defaults(handler=command_configure)

    subparsers.add_parser("status").set_defaults(handler=command_status)
    subparsers.add_parser("pause").set_defaults(handler=command_pause)

    resume = subparsers.add_parser("resume")
    resume.add_argument("--chat-id")
    resume.set_defaults(handler=command_resume)

    subparsers.add_parser("stop").set_defaults(handler=command_stop)

    for name, handler in (("run", command_run), ("start", command_start)):
        runtime = subparsers.add_parser(name)
        runtime.add_argument("--messages-db", required=True)
        runtime.add_argument("--poll-seconds", type=float, default=DEFAULT_POLL_SECONDS)
        runtime.add_argument("--codex-timeout", type=float, default=DEFAULT_CODEX_TIMEOUT)
        if name == "run":
            runtime.add_argument("--background-child", action="store_true", help=argparse.SUPPRESS)
        runtime.set_defaults(handler=handler)
    return parser


def main() -> int:
    os.umask(0o077)
    parser = build_parser()
    args = parser.parse_args()
    paths = Paths.from_root(Path(args.state_dir))
    try:
        return int(args.handler(args, paths))
    except AutopilotError as exc:
        emit({"ok": False, "error": exc.code, "message": str(exc)}, stream=sys.stderr)
        return exc.exit_code
    except (OSError, sqlite3.Error):
        emit(
            {
                "ok": False,
                "error": "controller_io_error",
                "message": "Autopilot state or process I/O failed safely",
            },
            stream=sys.stderr,
        )
        return 1
    except KeyboardInterrupt:
        emit({"ok": False, "error": "interrupted"}, stream=sys.stderr)
        return 130


if __name__ == "__main__":
    raise SystemExit(main())
