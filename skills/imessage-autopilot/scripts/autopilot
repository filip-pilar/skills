SCHEMA_VERSION = 1
CONTRACT_VERSION = 1
DEFAULT_POLL_SECONDS = 3.0
DEFAULT_CONTEXT_MESSAGES = 12
DEFAULT_CODEX_TIMEOUT = 90.0
DEFAULT_SETTLE_SECONDS = 0.5
MAX_BODY_CHARS = 16_384
MAX_REPLY_CHARS = 2_000
MAX_REASON_CHARS = 512
MAX_RETAINED_EVENTS_PER_CHAT = 256
MAX_PROTOCOL_BYTES = 1_048_576
MAX_NOTIFICATIONS = 4_096
CODEX_ALLOWED_ITEMS = {"userMessage", "reasoning", "agentMessage"}
CODEX_NOTIFICATION_OPT_OUTS = [
    "item/agentMessage/delta",
